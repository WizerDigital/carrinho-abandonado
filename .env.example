# Configurações do Banco de Dados
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=agent_db

# Configurações do Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Configurações do WAHA
WAHA_URL=https://your-waha-url.com
WAHA_SECRET_KEY=your_secret_key
WAHA_SESSION=default

# Configurações do App
PORT=3001
OPENAI_API_KEY=your_openai_api_key_here

# Tempo de espera (buffer) em milissegundos para acumular mensagens (debounce)
MESSAGE_BUFFER_TIME_MS=13000
